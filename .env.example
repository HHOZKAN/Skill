# Supabase — optionnel (sync cloud multi-appareils)
# Sans ces variables, l'app fonctionne entièrement en local (localStorage).
#
# 1. Créez un projet sur https://supabase.com
# 2. Exécutez ce SQL dans l'éditeur Supabase :
#
#    create table constellations_state (
#      id text primary key,
#      trees jsonb not null default '[]',
#      updated_at timestamptz default now()
#    );
#    -- Accès public (adapter selon vos besoins de sécurité)
#    alter table constellations_state enable row level security;
#    create policy "allow all" on constellations_state for all using (true);
#
# 3. Copiez ce fichier en .env.local et renseignez vos clés :

VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
